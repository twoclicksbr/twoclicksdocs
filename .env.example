APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

WEBHOOK_CODE_SECRET=
CLAUDE_BIN=claude
HORIZON_PREFIX=

# Tokens Sanctum por projeto (Code VPS) — ver config/twoclicks.php
TWOCLICKS_CODE_TOKEN_SMARTCLICK360=
TWOCLICKS_CODE_TOKEN_BETHEL360=
TWOCLICKS_CODE_TOKEN_APDIRETA=
TWOCLICKS_CODE_TOKEN_CLICKBANK=
TWOCLICKS_CODE_TOKEN_WHATSPANEL=
TWOCLICKS_CODE_TOKEN_DOCSTWOCLICKS=

# MCP reload hook — notifica MCP server para recarregar .env após criar/revogar token
# Endpoint POST /reload-tokens autenticado por X-Reload-Secret (ver docs/mcp-reload.md)
MCP_RELOAD_SECRET=
MCP_RELOAD_URL_SANDBOX=
MCP_RELOAD_URL_PROD=

# Sandbox dump (task #78) — restaurar tc_doc_sandbox a partir do tc_doc (prod)
# Ver app/Jobs/RestoreSandboxFromProdDumpJob.php
SANDBOX_DUMP_PROD_DB=tc_doc
SANDBOX_DUMP_PG_DUMP_BIN=/usr/bin/pg_dump
SANDBOX_DUMP_PSQL_BIN=/usr/bin/psql
